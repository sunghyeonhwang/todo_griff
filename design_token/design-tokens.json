{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "Structured Planner Design Tokens",
  "version": "1.0.0",
  "description": "Structured 스타일 데일리 타임블록 플래너 디자인 토큰",

  "color": {
    "block": {
      "blue":   { "bg": "#E8F0FE", "fg": "#1A73E8", "solid": "#4285F4", "border": "#C6DAFC" },
      "green":  { "bg": "#E6F4EA", "fg": "#1E8E3E", "solid": "#34A853", "border": "#C4E7CE" },
      "orange": { "bg": "#FEF0E3", "fg": "#E8710A", "solid": "#FA903E", "border": "#FBDDC3" },
      "red":    { "bg": "#FCE8E6", "fg": "#D93025", "solid": "#EA4335", "border": "#F7C6C2" },
      "purple": { "bg": "#F3E8FD", "fg": "#8430CE", "solid": "#A250E8", "border": "#E3CBF9" },
      "pink":   { "bg": "#FCE4EC", "fg": "#D01884", "solid": "#EC4899", "border": "#F8C6DD" },
      "teal":   { "bg": "#E0F7F5", "fg": "#00897B", "solid": "#14B8A6", "border": "#B8ECE6" },
      "gray":   { "bg": "#F1F3F4", "fg": "#5F6368", "solid": "#9AA0A6", "border": "#DADCE0" }
    },
    "surface": {
      "light": {
        "background":     "#F7F8FA",
        "card":           "#FFFFFF",
        "cardElevated":   "#FFFFFF",
        "timelineLine":   "#EAECEF",
        "timelineLabel":  "#9AA0A6",
        "nowIndicator":   "#EA4335",
        "overlay":        "rgba(0,0,0,0.4)"
      },
      "dark": {
        "background":     "#0F1114",
        "card":           "#1C1F24",
        "cardElevated":   "#262A30",
        "timelineLine":   "#2A2E34",
        "timelineLabel":  "#7A8085",
        "nowIndicator":   "#FF6B5E",
        "overlay":        "rgba(0,0,0,0.6)"
      }
    },
    "text": {
      "light": {
        "primary":   "#1F2226",
        "secondary": "#5F6368",
        "tertiary":  "#9AA0A6",
        "onSolid":   "#FFFFFF"
      },
      "dark": {
        "primary":   "#F1F3F4",
        "secondary": "#B4B9BF",
        "tertiary":  "#7A8085",
        "onSolid":   "#FFFFFF"
      }
    },
    "accent": {
      "primary":   "#4285F4",
      "success":   "#34A853",
      "warning":   "#FA903E",
      "danger":    "#EA4335"
    }
  },

  "typography": {
    "fontFamily": {
      "sans": "-apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Pretendard', 'Segoe UI', Roboto, sans-serif",
      "mono": "'SF Mono', 'Roboto Mono', 'JetBrains Mono', monospace"
    },
    "fontSize": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "15px",
      "md":   "17px",
      "lg":   "20px",
      "xl":   "24px",
      "2xl":  "28px",
      "3xl":  "34px"
    },
    "fontWeight": {
      "regular":  "400",
      "medium":   "500",
      "semibold": "600",
      "bold":     "700"
    },
    "lineHeight": {
      "tight":   "1.2",
      "normal":  "1.4",
      "relaxed": "1.6"
    },
    "letterSpacing": {
      "tight":  "-0.02em",
      "normal": "0",
      "wide":   "0.02em"
    }
  },

  "spacing": {
    "0":  "0px",
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },

  "radius": {
    "none": "0px",
    "sm":   "8px",
    "md":   "12px",
    "lg":   "16px",
    "xl":   "20px",
    "2xl":  "28px",
    "full": "9999px"
  },

  "shadow": {
    "light": {
      "sm":  "0 1px 2px rgba(15,17,20,0.06)",
      "md":  "0 2px 8px rgba(15,17,20,0.08)",
      "lg":  "0 8px 24px rgba(15,17,20,0.12)",
      "block": "0 1px 3px rgba(15,17,20,0.10)"
    },
    "dark": {
      "sm":  "0 1px 2px rgba(0,0,0,0.30)",
      "md":  "0 2px 8px rgba(0,0,0,0.40)",
      "lg":  "0 8px 24px rgba(0,0,0,0.50)",
      "block": "0 1px 3px rgba(0,0,0,0.35)"
    }
  },

  "layout": {
    "appMaxWidth":     "480px",
    "hourHeight":      "64px",
    "pxPerMinute":     "1.0667",
    "timeLabelWidth":  "60px",
    "snapMinutes":     "15",
    "blockMinHeight":  "24px",
    "nowIndicatorWidth": "2px"
  },

  "motion": {
    "duration": {
      "fast":   "120ms",
      "base":   "200ms",
      "slow":   "320ms"
    },
    "easing": {
      "standard":  "cubic-bezier(0.4, 0.0, 0.2, 1)",
      "decelerate": "cubic-bezier(0.0, 0.0, 0.2, 1)",
      "accelerate": "cubic-bezier(0.4, 0.0, 1, 1)",
      "spring":    "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },

  "zIndex": {
    "base":         "0",
    "block":        "10",
    "nowIndicator": "20",
    "dragging":     "30",
    "header":       "40",
    "modal":        "50",
    "toast":        "60"
  }
}
